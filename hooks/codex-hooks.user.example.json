{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/workspace/.aoa/scripts/aoa_session_memory.py hook --event-name SessionStart --workspace-root /path/to/workspace --aoa-root /path/to/workspace/.aoa",
            "statusMessage": "AoA session memory start",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/workspace/.aoa/scripts/aoa_session_memory.py hook --event-name UserPromptSubmit --workspace-root /path/to/workspace --aoa-root /path/to/workspace/.aoa",
            "statusMessage": "AoA session memory prompt",
            "timeout": 20
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/workspace/.aoa/scripts/aoa_session_memory.py hook --event-name PreCompact --workspace-root /path/to/workspace --aoa-root /path/to/workspace/.aoa",
            "statusMessage": "AoA session memory pre-compact",
            "timeout": 30
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/workspace/.aoa/scripts/aoa_session_memory.py hook --event-name PostCompact --workspace-root /path/to/workspace --aoa-root /path/to/workspace/.aoa",
            "statusMessage": "AoA session memory post-compact",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/workspace/.aoa/scripts/aoa_session_memory.py hook --event-name Stop --workspace-root /path/to/workspace --aoa-root /path/to/workspace/.aoa",
            "statusMessage": "AoA session memory stop",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
