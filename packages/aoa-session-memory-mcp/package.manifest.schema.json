{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/8Dionysus/aoa-session-memory/blob/main/packages/aoa-session-memory-mcp/package.manifest.schema.json",
  "title": "AoA session-memory MCP package projection manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "projection",
    "upstream",
    "package",
    "compatibility",
    "entrypoints",
    "root_discovery",
    "authority_boundary",
    "mcp_surface",
    "allowed_differences",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "aoa_session_memory_mcp_package_manifest_v1"
    },
    "schema_version": {
      "const": 1
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "owner_decision", "export_tool", "policy"],
      "properties": {
        "mode": {"const": "one-way-owner-export"},
        "owner_decision": {"const": "ABYSS-STACK-D-0084"},
        "export_tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "version"],
          "properties": {
            "path": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1}
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "sha256"],
          "properties": {
            "schema": {"const": "aoa_session_memory_mcp_package_export_policy_v1"},
            "sha256": {"$ref": "#/$defs/sha256"}
          }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit", "commit_epoch", "source_path"],
      "properties": {
        "repository": {"type": "string", "format": "uri"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "commit_epoch": {"type": "integer", "minimum": 1},
        "source_path": {"type": "string", "minLength": 1}
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distribution", "module", "version", "description", "license"],
      "properties": {
        "distribution": {"const": "aoa-session-memory-mcp"},
        "module": {"const": "aoa_session_memory_mcp"},
        "version": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "license": {"type": "string", "minLength": 1}
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "mcp_sdk"],
      "properties": {
        "python": {"type": "string", "minLength": 1},
        "mcp_sdk": {"type": "string", "minLength": 1}
      }
    },
    "entrypoints": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "root_discovery": {"type": "object"},
    "authority_boundary": {
      "type": "object",
      "required": ["schema", "mcp_role", "service_owner", "mutation_posture", "stop_lines"]
    },
    "mcp_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "tools", "resources", "resource_templates", "prompts"],
      "properties": {
        "schema": {"const": "aoa_session_memory_mcp_surface_catalog_v1"},
        "tools": {"type": "array", "items": {"type": "object"}},
        "resources": {"type": "array", "items": {"type": "object"}},
        "resource_templates": {"type": "array", "items": {"type": "object"}},
        "prompts": {"type": "array", "items": {"type": "object"}}
      }
    },
    "allowed_differences": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size", "mode", "source"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/sha256"},
          "size": {"type": "integer", "minimum": 0},
          "mode": {"enum": ["0644", "0755"]},
          "source": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
