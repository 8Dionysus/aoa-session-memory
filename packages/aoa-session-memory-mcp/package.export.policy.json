{
  "schema": "aoa_session_memory_mcp_package_export_policy_v1",
  "version": 1,
  "upstream_repository": "https://github.com/8Dionysus/abyss-stack",
  "owner_decision": "ABYSS-STACK-D-0084",
  "owner_source_path": "mcp/services/aoa-session-memory-mcp",
  "downstream_repository": "https://github.com/8Dionysus/aoa-session-memory",
  "downstream_package_path": "packages/aoa-session-memory-mcp",
  "include_globs": [
    "pyproject.toml",
    "README.md",
    "DESIGN.md",
    "docs/*.md",
    "scripts/aoa_session_memory_mcp_server.py",
    "scripts/validate_session_memory_mcp.py",
    "src/**/*.py",
    "tests/conftest.py",
    "tests/test_session_memory_mcp.py"
  ],
  "mapped_files": [
    {
      "source": "projection/README.md",
      "destination": "PROJECTION.md"
    },
    {
      "source": "projection/package-export.policy.json",
      "destination": "package.export.policy.json"
    },
    {
      "source": "projection/package.manifest.schema.json",
      "destination": "package.manifest.schema.json"
    },
    {
      "source": "projection/validate_package_projection.py",
      "destination": "scripts/validate_package_projection.py"
    },
    {
      "source": "projection/release_check.py",
      "destination": "scripts/release_check.py"
    },
    {
      "source": "projection/test_package_projection.py",
      "destination": "tests/test_package_projection.py"
    }
  ],
  "repository_files": [
    {
      "source": "LICENSE",
      "destination": "LICENSE"
    }
  ],
  "excluded_path_parts": [
    ".env",
    ".git",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
    ".venv",
    "__pycache__",
    "build",
    "dist",
    "logs",
    "runtime",
    "secrets",
    "venv"
  ],
  "excluded_suffixes": [
    ".db",
    ".log",
    ".pyc",
    ".sqlite",
    ".sqlite3"
  ],
  "allowed_differences": [
    "The downstream package manifest is generated by the owner-side exporter.",
    "Stack-owned systemd, authenticated loopback HTTP, bearer credential, and /srv launch profiles are not projected.",
    "Repository-owned examples, CI, release instructions, and public landing documentation live outside the projected package directory."
  ]
}
