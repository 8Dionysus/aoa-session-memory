{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AoA compaction segment index",
  "type": "object",
  "required": [
    "schema_version",
    "generation_id",
    "generation_identity",
    "projection_publish",
    "segment_id",
    "source_raw",
    "source_block",
    "events",
    "by_type",
    "by_tag"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "generation_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generation_identity": {
      "type": "object",
      "required": ["generation_id", "projection", "schema_version", "producer", "producer_sha256"],
      "properties": {
        "generation_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "projection": {"const": "segment_index"},
        "schema_version": {"type": "integer", "minimum": 1},
        "producer": {"type": "string", "minLength": 1},
        "producer_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      },
      "additionalProperties": true
    },
    "projection_publish": {
      "type": "object",
      "required": ["schema_version", "publish_id", "source", "processed_watermark", "dependency_generations"],
      "properties": {
        "schema_version": {"type": "integer", "minimum": 1},
        "publish_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source": {
          "type": "object",
          "required": ["raw_sha256", "raw_bytes", "raw_line_count"],
          "additionalProperties": true
        },
        "processed_watermark": {"type": "object"},
        "dependency_generations": {"type": "object"}
      },
      "additionalProperties": true
    },
    "segment_id": {"type": "string"},
    "segment_role": {"type": "string"},
    "source_raw": {"type": "string"},
    "source_range": {
      "type": "object",
      "required": ["from_line", "to_line"],
      "properties": {
        "from_line": {"type": "integer", "minimum": 1},
        "to_line": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "source_block": {"type": "object"},
    "events": {"type": "array", "items": {"type": "object"}},
    "by_type": {"type": "object"},
    "by_tag": {"type": "object"},
    "by_family": {"type": "object"},
    "by_phase": {"type": "object"},
    "by_actor": {"type": "object"},
    "by_action": {"type": "object"},
    "by_outcome": {"type": "object"},
    "by_correlation": {"type": "object"},
    "by_conversation_act": {"type": "object"},
    "by_session_act": {"type": "object"},
    "route_signal_schema_version": {"type": "integer"},
    "by_route_layer": {"type": "object"},
    "by_route_signal": {"type": "object"}
  },
  "additionalProperties": true
}
