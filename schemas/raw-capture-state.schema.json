{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AoA raw capture state",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "session_id",
    "status",
    "capture_id",
    "capture_path",
    "capture_ref",
    "raw_sha256",
    "raw_bytes",
    "raw_line_count",
    "captured_at",
    "source_path",
    "source_snapshot_before",
    "source_snapshot_after",
    "source_stable_during_capture",
    "projection_freshness",
    "authority",
    "projection_authority"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_type": {"const": "raw_capture_state"},
    "session_id": {"type": "string", "minLength": 1},
    "status": {
      "enum": [
        "preserved_unindexed",
        "preserved_unstable_unindexed",
        "captured_matches_indexed_projection",
        "indexed_with_projection"
      ]
    },
    "capture_id": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "capture_path": {"type": "string", "minLength": 1},
    "capture_ref": {"type": "string", "minLength": 1},
    "preserved_capture_path": {"type": "string"},
    "raw_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "raw_bytes": {"type": "integer", "minimum": 0},
    "raw_line_count": {"type": "integer", "minimum": 0},
    "captured_at": {"type": "string", "minLength": 1},
    "source_path": {"type": "string", "minLength": 1},
    "source_snapshot_before": {"$ref": "#/$defs/fileSnapshot"},
    "source_snapshot_after": {"$ref": "#/$defs/fileSnapshot"},
    "source_stable_during_capture": {"type": "boolean"},
    "hooks_seen": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "projection_publish_id_at_capture": {"type": "string"},
    "projection_raw_sha256_at_capture": {"type": "string"},
    "projection_publish_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "projection_freshness": {"enum": ["current", "stale-readable", "deferred"]},
    "authority": {"const": "preserved_raw_evidence"},
    "projection_authority": {"const": false},
    "next_route": {"type": "string"}
  },
  "$defs": {
    "fileSnapshot": {
      "type": "object",
      "required": ["path", "size", "mtime_ns"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "mtime_ns": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "indexed_with_projection"}}},
      "then": {"required": ["projection_publish_id"]}
    }
  ],
  "additionalProperties": true
}
