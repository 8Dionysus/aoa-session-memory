{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/atlas-route-entry.schema.json",
  "title": "AoA Session Memory Atlas Route Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_identity",
    "generation_identity",
    "axis",
    "route_key",
    "status",
    "truth_status",
    "session",
    "confidence",
    "next_route",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "artifact_identity": {
      "$ref": "#/$defs/artifactIdentity"
    },
    "generation_identity": {
      "$ref": "#/$defs/generationIdentity"
    },
    "axis": {
      "type": "string",
      "pattern": "^by-[a-z0-9-]+$"
    },
    "route_key": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["generated", "stale", "diagnostic", "reviewed"]
    },
    "truth_status": {
      "type": "string",
      "enum": ["route_signal_not_reviewed_truth", "reviewed_distillation"]
    },
    "session": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "session_date": {
      "type": "string",
      "pattern": "^(20[0-9]{2}-[01][0-9]-[0-3][0-9])?$"
    },
    "work_context": {
      "type": "string"
    },
    "work_family": {
      "type": "string"
    },
    "authority_surface": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "signal_count": {
      "type": "integer",
      "minimum": 0
    },
    "route_layer": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "none"]
    },
    "next_route": {
      "type": "string"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "session_ref": {
          "type": "string"
        },
        "segment_ref": {
          "type": "string"
        },
        "raw_ref": {
          "type": "string"
        },
        "generated_index_ref": {
          "type": "string"
        },
        "diagnostic_ref": {
          "type": "string"
        },
        "external_ref": {
          "type": "string"
        }
      }
    },
    "related_axes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^by-[a-z0-9-]+$"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "generationIdentity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "contract_version",
        "projection",
        "schema_version",
        "producer",
        "producer_sha256",
        "generation_id"
      ],
      "properties": {
        "contract_version": {
          "type": "integer",
          "minimum": 1
        },
        "projection": {
          "type": "string",
          "const": "agent_atlas"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 2
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "producer_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "generation_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "artifactIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "surface_state",
        "owner_repo",
        "authority_ref",
        "producer",
        "consumer_expectation",
        "privacy_boundary",
        "content_identity",
        "abi_epoch",
        "contract_version",
        "trust_layer",
        "verification",
        "action"
      ],
      "properties": {
        "artifact_class": {
          "type": "string",
          "const": "session_memory_atlas_route_entry"
        },
        "surface_state": {
          "type": "string",
          "const": "portable_generated_session_route_packet"
        },
        "owner_repo": {
          "type": "string",
          "const": "aoa-session-memory"
        },
        "authority_ref": {
          "type": "string",
          "const": "maps/README.md"
        },
        "producer": {
          "type": "string",
          "minLength": 3
        },
        "consumer_expectation": {
          "type": "string",
          "minLength": 3
        },
        "privacy_boundary": {
          "type": "string",
          "minLength": 3
        },
        "content_identity": {
          "type": "string",
          "minLength": 3
        },
        "abi_epoch": {
          "type": "string",
          "const": "aoa_session_memory_atlas_route_entry_v1"
        },
        "contract_version": {
          "type": "string",
          "minLength": 3
        },
        "trust_layer": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "action": {
          "type": "string",
          "minLength": 3
        }
      }
    }
  }
}
