{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abyssos.local/schemas/aoa/token-accounting.schema.json",
  "title": "AoA Token Accounting",
  "description": "Count-only token accounting observation or aggregate. Estimates are never exact usage facts.",
  "type": "object",
  "required": ["schema", "schema_version", "privacy"],
  "properties": {
    "schema": {
      "const": "abyss_token_accounting_v1"
    },
    "schema_version": {
      "const": 1
    },
    "generator_version": {
      "type": "integer",
      "minimum": 1
    },
    "event_id": {
      "type": "string"
    },
    "raw_ref": {
      "type": "string"
    },
    "timestamp": {
      "type": ["string", "null"]
    },
    "source_type": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "source_kind": {
      "type": "string"
    },
    "count_basis": {
      "enum": ["provider_reported", "exact_tokenizer", "estimated", "unknown"]
    },
    "tokenizer_id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "payload_path": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "privacy": {
      "type": "object",
      "required": ["raw_text_logged", "prompt_text_logged", "stores_counts_only", "stores_refs"],
      "properties": {
        "raw_text_logged": {
          "const": false
        },
        "prompt_text_logged": {
          "const": false
        },
        "stores_counts_only": {
          "const": true
        },
        "stores_refs": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cached_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "reasoning_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "context_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "context_window_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "observed_event_count": {
      "type": "integer",
      "minimum": 0
    },
    "provider_reported_event_count": {
      "type": "integer",
      "minimum": 0
    },
    "estimated_event_count": {
      "type": "integer",
      "minimum": 0
    },
    "observation_count": {
      "type": "integer",
      "minimum": 0
    },
    "count_by_basis": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "totals_by_basis": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "$ref": "#"
      }
    },
    "basis_rule": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
